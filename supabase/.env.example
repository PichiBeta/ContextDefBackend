# ContextDefBackend — required secrets
#
# SETUP:
#   cp supabase/.env.example supabase/.env.local
#   Fill in real values in supabase/.env.local (it is gitignored).
#
# PRODUCTION:
#   supabase secrets set KEY=value --project-ref <ref>
#
# Note: Supabase only returns secret names/digests, not plaintext values.
# Contact a team member for the actual values.

# ── Edge Function Secrets ────────────────────────────────────────────────────
# Set via: supabase secrets set KEY=value --project-ref <ref>

# Anthropic Claude API key — used by defintion-translation for word definitions
ANTHROPIC_API_KEY=

# Azure Document Intelligence endpoint URL — used by ocr-extract
# Format: https://<resource-name>.cognitiveservices.azure.com
AZURE_DOC_INTEL_ENDPOINT=

# Azure Document Intelligence subscription key — used by ocr-extract
AZURE_DOC_INTEL_KEY=

# HuggingFace Inference API key — used by calculate_user_embedding for embeddings
# Model: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
HF_API_KEY=

# Webhook shared secret — used by process-reading and calculate-difficulty
# to authenticate calls from the DB trigger (pg_net).
# Must match the vault secret READINGS_DIFFICULTY_WEBHOOK_SECRET (see below).
READINGS_DIFFICULTY_WEBHOOK_SECRET=

# Supabase anonymous/publishable key — used by create-reading for JWT auth
SUPABASE_ANON_KEY=

# Supabase Postgres connection URL — used for direct DB access
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# Supabase service role key — bypasses RLS. Used by process-reading,
# calculate-difficulty, and calculate_user_embedding. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project URL — used by all functions
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=

# ── Vault Secrets ────────────────────────────────────────────────────────────
# Stored in the DB via Supabase Vault (Dashboard > Vault, or `supabase vault create`).
# These are read by Postgres trigger code, not by edge functions directly.

# Vault-stored copy of the webhook secret — read by the readings_enqueue_difficulty
# trigger in Postgres. Must equal READINGS_DIFFICULTY_WEBHOOK_SECRET above.
READINGS_DIFFICULTY_WEBHOOK_SECRET=

# Vault secret for the temp_readings trigger (prototype table). Same value as above.
TEMP_READINGS_DIFFICULTY_WEBHOOK_SECRET=

# ── Local Development Only ───────────────────────────────────────────────────
# Used by Supabase Studio AI features in local dev (config.toml reference).
# Not deployed to production and not used by any edge function.
OPENAI_API_KEY=

# ── Orphaned Dashboard Secrets ───────────────────────────────────────────────
# These exist as dashboard secrets but are not referenced by any function code.
# Investigate before removing from the dashboard.
GEMINI_API_KEY=
OPEN_API_KEY=
